# CESSDA MCP Server Configuration
# Copy this file to .env and adjust values as needed

# API Configuration
CESSDA_API_BASE_URL=https://datacatalogue.cessda.eu/api
CESSDA_API_TIMEOUT=30
CESSDA_API_MAX_RETRIES=3

# Logging Configuration
# Valid levels: DEBUG, INFO, WARN, ERROR
CESSDA_LOG_LEVEL=WARN

# Default Search Parameters
CESSDA_DEFAULT_LANGUAGE=en
CESSDA_DEFAULT_LIMIT=10
CESSDA_MAX_LIMIT=200
